# ICS Risk Assessment Framework - Environment Configuration

# Database URL (default: sqlite:///backend/data/ICSRiskFramework.db)
# For SQLite: sqlite:///path/to/database.db
# For PostgreSQL: postgresql://user:password@host:port/database
ICS_DB_URL=sqlite:///backend/data/ICSRiskFramework.db

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
# For development: http://localhost:5173
# For production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# File upload limits
MAX_UPLOAD_SIZE_MB=10

